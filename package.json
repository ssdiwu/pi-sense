{
  "name": "pi-sense",
  "version": "0.0.1",
  "description": "Pi extension that gives text-only models media understanding — describes images directly, routes local videos through native understanding for what-questions or frames+local ASR for when-questions, then feeds text to non-vision models",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "vision",
    "image",
    "video",
    "handoff",
    "multimodal"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "video.ts",
    "asr.ts",
    "native-video.ts",
    "scripts",
    "doc",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ssdiwu/pi-sense.git"
  },
  "homepage": "https://github.com/ssdiwu/pi-sense#readme",
  "bugs": {
    "url": "https://github.com/ssdiwu/pi-sense/issues"
  }
}
